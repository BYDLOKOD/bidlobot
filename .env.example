# BidloBot local/dev environment template. Copy to `.env` and fill in.
# `.env` is gitignored; only this `.env.example` is tracked. Never
# commit a populated env file (CI runs gitleaks to catch it).

# Required: telegram bot token from @BotFather. Format \d+:[A-Za-z0-9_-]{35,}.
TG_BOT_TOKEN=

# Required: Telegram user ID of the bot owner. Only this user may add
# the bot to a supergroup. Non-owner adds trigger an immediate LeaveChat.
BOT_OWNER_ID=

# Optional. bbolt directory; default ./data locally.
DB_PATH=./data

# debug | info | warn | error. Default: info.
LOG_LEVEL=info

# Pi/OMP chat summarization. The image supplies the Pi binary; OMP receives
# its provider credential directly from this environment, never BidloBot config.
# PI_BINARY=omp
# PI_MODEL=deepseek/deepseek-v4-flash
DEEPSEEK_API_KEY=
