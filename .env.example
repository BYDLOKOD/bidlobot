# BidloBot local/dev environment template. Copy to `.env` and fill in.
# `.env` is gitignored; only this `.env.example` is tracked. Never
# commit a populated env file (CI runs gitleaks to catch it).

# Required: telegram bot token from @BotFather. Format \d+:[A-Za-z0-9_-]{35,}.
TG_BOT_TOKEN=

# Optional. bbolt directory; default ./data locally.
DB_PATH=./data

# debug | info | warn | error. Default: info.
LOG_LEVEL=info

# Optional: chat summarization via Zhipu GLM. Empty disables the
# feature; the bot still starts. The key is the "{id}.{secret}" string
# from the provider console - secret, never logged, never committed.
#
# Pick the endpoint that matches your key:
#  - Standard pay-as-you-go key: leave the overrides unset (defaults
#    are https://open.bigmodel.cn/api/paas/v4 + glm-5). Needs a funded
#    account; an empty balance returns provider code 1113.
#  - GLM Coding Plan subscription key: it works ONLY on the coding
#    endpoint; the general endpoint returns 1113 ("no resource
#    package"). Set the two overrides below. NOTE: z.ai states the
#    coding endpoint is for supported coding tools - using it for this
#    bot is outside that intended use and may risk the account.
GLM_API_KEY=
# GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# GLM_MODEL=glm-4.6
