# BidloBot local/dev environment template. Copy to `.env` and fill in.
# `.env` is gitignored; only this `.env.example` is tracked. Never
# commit a populated env file (CI runs gitleaks to catch it).

# Required: telegram bot token from @BotFather. Format \d+:[A-Za-z0-9_-]{35,}.
TG_BOT_TOKEN=

# Optional. bbolt directory; default ./data locally.
DB_PATH=./data

# debug | info | warn | error. Default: info.
LOG_LEVEL=info

# Optional: chat summarization via Zhipu GLM (open.bigmodel.cn).
# Empty disables the feature; the bot still starts. The key is the
# "{id}.{secret}" string from the provider console - secret, never
# logged, never committed. Needs a funded provider account.
GLM_API_KEY=
# Optional overrides (defaults: open.bigmodel.cn v4 / glm-5):
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-5
