# BidloBot environment file template.
#
# On the production host, install this as /etc/bidlobot/env (mode 0640,
# owned root:root or root:bidlobot). docker-compose.yml bind-mounts it
# via env_file. Never commit the populated file to git.

# Required: telegram bot token from @BotFather. Format \d+:[A-Za-z0-9_-]{35,}.
TG_BOT_TOKEN=

# Optional. Override only if the in-image default is wrong.
# DB_PATH defaults to /var/lib/bidlobot inside the container - leave
# unset unless you know why you'd point bbolt elsewhere.
# DB_PATH=/var/lib/bidlobot

# debug | info | warn | error. Default: info.
LOG_LEVEL=info

# 0 disables the health endpoint entirely. The compose healthcheck
# expects 8080 inside the container; only override if you also rewrite
# the healthcheck.test in compose.
# HEALTH_PORT=8080

# Optional: chat summarization via Zhipu GLM. Leave GLM_API_KEY empty
# to disable the feature entirely - the bot starts and runs normally
# without it; /summarize then replies "not configured" to admins. The
# key is the "{id}.{secret}" string from the provider console; held in
# memory only, never logged. Treat this file as a secret.
#
# Match the endpoint to your key type:
#  - Standard pay-as-you-go key: leave the overrides unset (defaults
#    https://open.bigmodel.cn/api/paas/v4 + glm-5). Needs a funded
#    account; an empty balance returns provider code 1113.
#  - GLM Coding Plan subscription key: works ONLY on the coding
#    endpoint (general endpoint returns 1113 "no resource package").
#    Set both overrides. z.ai states the coding endpoint is for
#    supported coding tools - using it for this bot is outside that
#    intended use and may risk the account; an operator/ToS decision.
GLM_API_KEY=
# GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# GLM_MODEL=glm-4.6
