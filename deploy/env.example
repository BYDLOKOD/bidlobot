# BidloBot deployment environment template.
#
# On the production host, install this as /etc/bidlobot/env (mode 0640,
# owned root:root or root:bidlobot). docker-compose.yml bind-mounts it
# via env_file. Never commit the populated file to git.

# Required: telegram bot token from @BotFather. Format \d+:[A-Za-z0-9_-]{35,}.
TG_BOT_TOKEN=

# Required: Telegram user ID of the bot owner. Only this user may add
# the bot to a supergroup. Non-owner adds trigger an immediate LeaveChat.
BOT_OWNER_ID=

# Optional. Override only if the in-image default is wrong.
# DB_PATH defaults to /var/lib/bidlobot inside the container - leave
# unset unless you know why you'd point bbolt elsewhere.
# DB_PATH=/var/lib/bidlobot

# debug | info | warn | error. Default: info.
LOG_LEVEL=info

# 0 disables the health endpoint entirely. The compose healthcheck
# expects 8080 inside the container; only override if you also rewrite
# the healthcheck.test in compose.
# HEALTH_PORT=8080

# --- Inactive-cleanup campaign tuning ---
# NO enable flag. The campaign is started per-chat by an admin's
# `/cleanup <period>` confirm (and stopped by `/cleanup stop`); the
# daily scheduler is always on but idle until a campaign exists.
# These only tune pacing; unset = safe default.
# UTC HH:MM the daily campaign tick fires.
# CLEANUP_DAILY_AT=10:00
# Delay between the public tag and the kick. Range 1h..720h.
# CLEANUP_GRACE=72h
# Max members publicly tagged per chat per day. Range 1..50.
# CLEANUP_DAILY_BATCH=15

# Pi/OMP chat summarization (always on). The Pi binary is inside the
# image (Bun 1.3.14 + @oh-my-pi/pi-coding-agent 16.3.6).
# PI_BINARY defaults to "omp"; PI_MODEL defaults to "deepseek/deepseek-v4-flash".
# Override only for a custom Pi distribution or model.
# PI_BINARY=omp
# PI_MODEL=deepseek/deepseek-v4-flash

# Pi reads this provider credential directly from the container environment.
# It is not parsed, stored, or logged by BidloBot.
DEEPSEEK_API_KEY=
