;; chat-stats/messages.edn
;; Sample Telegram message updates of various types.
;; Each entry has :update (Telegram update structure) and :expected
;; with :count? flag indicating whether this message should increment stats.

{:description "Telegram message updates for stats collection testing"

 :chat {:id -1001234567890
        :title "Clojure Russia"
        :type "supergroup"}

 :messages
 [;; --- Text messages (should count) ---
  {:update {:update_id 100001
            :message {:message_id 5001
                      :from {:id 111222333
                             :is_bot false
                             :first_name "Alexey"
                             :username "alexey_dev"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582400
                      :text "Has anyone tried Datomic Cloud?"}}
   :expected {:count? true
              :user-id 111222333
              :chat-id -1001234567890}}

  {:update {:update_id 100002
            :message {:message_id 5002
                      :from {:id 222333444
                             :is_bot false
                             :first_name "Marina"
                             :username "marina_fp"
                             :language_code "en"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582460
                      :text "Yes, we migrated last month. Works great with XTDB as well."}}
   :expected {:count? true
              :user-id 222333444
              :chat-id -1001234567890}}

  ;; --- Photo message (should count) ---
  {:update {:update_id 100003
            :message {:message_id 5003
                      :from {:id 333444555
                             :is_bot false
                             :first_name "Dmitry"
                             :username "dmi3_arch"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582520
                      :photo [{:file_id "AgACAgIAAxkBAAIBi2X" :width 90 :height 90}
                              {:file_id "AgACAgIAAxkBAAIBi2Y" :width 320 :height 320}
                              {:file_id "AgACAgIAAxkBAAIBi2Z" :width 800 :height 800}]
                      :caption "Architecture diagram for the new service"}}
   :expected {:count? true
              :user-id 333444555
              :chat-id -1001234567890}}

  ;; --- Sticker message (should count) ---
  {:update {:update_id 100004
            :message {:message_id 5004
                      :from {:id 111222333
                             :is_bot false
                             :first_name "Alexey"
                             :username "alexey_dev"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582580
                      :sticker {:file_id "CAACAgIAAxkBAAICaGX"
                                :type "regular"
                                :width 512
                                :height 512
                                :emoji "👍"
                                :set_name "HotCherry"}}}
   :expected {:count? true
              :user-id 111222333
              :chat-id -1001234567890}}

  ;; --- Video message (should count) ---
  {:update {:update_id 100005
            :message {:message_id 5005
                      :from {:id 444555666
                             :is_bot false
                             :first_name "Pavel"
                             :username "pavel_clj"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582640
                      :video {:file_id "BAACAgIAAxkBAAIBk2X"
                              :width 1920
                              :height 1080
                              :duration 45}
                      :caption "Quick demo of the REPL workflow"}}
   :expected {:count? true
              :user-id 444555666
              :chat-id -1001234567890}}

  ;; --- Document message (should count) ---
  {:update {:update_id 100006
            :message {:message_id 5006
                      :from {:id 555666777
                             :is_bot false
                             :first_name "Olga"
                             :username "olga_data"
                             :language_code "en"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582700
                      :document {:file_id "BQACAgIAAxkBAAICb2X"
                                 :file_name "benchmark-results.pdf"
                                 :mime_type "application/pdf"
                                 :file_size 245760}}}
   :expected {:count? true
              :user-id 555666777
              :chat-id -1001234567890}}

  ;; --- Edited message (should NOT count) ---
  {:update {:update_id 100007
            :edited_message {:message_id 5001
                             :from {:id 111222333
                                    :is_bot false
                                    :first_name "Alexey"
                                    :username "alexey_dev"
                                    :language_code "ru"}
                             :chat {:id -1001234567890
                                    :title "Clojure Russia"
                                    :type "supergroup"}
                             :date 1772582400
                             :edit_date 1772582800
                             :text "Has anyone tried Datomic Cloud? Specifically v2?"}}
   :expected {:count? false
              :reason :edited-message}}

  ;; --- Service message: new member joined (should NOT count) ---
  {:update {:update_id 100008
            :message {:message_id 5007
                      :from {:id 666777888
                             :is_bot false
                             :first_name "Igor"
                             :username "igor_newbie"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582860
                      :new_chat_members [{:id 666777888
                                          :is_bot false
                                          :first_name "Igor"
                                          :username "igor_newbie"}]}}
   :expected {:count? false
              :reason :service-message}}

  ;; --- Service message: member left (should NOT count) ---
  {:update {:update_id 100009
            :message {:message_id 5008
                      :from {:id 777888999
                             :is_bot false
                             :first_name "Sergey"
                             :username "sergey_gone"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582920
                      :left_chat_member {:id 777888999
                                         :is_bot false
                                         :first_name "Sergey"
                                         :username "sergey_gone"}}}
   :expected {:count? false
              :reason :service-message}}

  ;; --- Bot message (should NOT count) ---
  {:update {:update_id 100010
            :message {:message_id 5009
                      :from {:id 987654321
                             :is_bot true
                             :first_name "DoxMe Bot"
                             :username "doxme_bot"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772582980
                      :text "Welcome to Clojure Russia! Use /register to create your profile."}}
   :expected {:count? false
              :reason :bot-message}}

  ;; --- Service message: chat title changed (should NOT count) ---
  {:update {:update_id 100011
            :message {:message_id 5010
                      :from {:id 111222333
                             :is_bot false
                             :first_name "Alexey"
                             :username "alexey_dev"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure & Friends"
                             :type "supergroup"}
                      :date 1772583040
                      :new_chat_title "Clojure & Friends"}}
   :expected {:count? false
              :reason :service-message}}

  ;; --- Service message: pinned message (should NOT count) ---
  {:update {:update_id 100012
            :message {:message_id 5011
                      :from {:id 111222333
                             :is_bot false
                             :first_name "Alexey"
                             :username "alexey_dev"
                             :language_code "ru"}
                      :chat {:id -1001234567890
                             :title "Clojure Russia"
                             :type "supergroup"}
                      :date 1772583100
                      :pinned_message {:message_id 5002
                                       :text "Yes, we migrated last month."}}}
   :expected {:count? false
              :reason :service-message}}]}
