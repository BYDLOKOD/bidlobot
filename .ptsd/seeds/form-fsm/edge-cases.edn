;; edge-cases.edn
;; Edge cases for the form FSM: expired sessions, skip on required,
;; back on first step, resume existing session, stale callbacks.

[;; === Expired session (older than 7 days) ===
 {:scenario :expired-session
  :session {:state :step/stack
            :step-idx 1
            :data {:salary "100k USD"}
            :created-at #inst "2026-02-20T10:00:00Z"
            :user-id 111222
            :chat-id -100200300}
  :action :input
  :input "Clojure"
  :current-time #inst "2026-03-01T10:00:00Z"
  :expected {:error :session-expired}
  :note "Session created 9 days ago, exceeds 7-day TTL"}

 ;; === Skip on required field (salary) ===
 {:scenario :skip-required-salary
  :session {:state :step/salary
            :step-idx 0
            :data {}
            :created-at #inst "2026-03-01T10:00:00Z"
            :user-id 111222
            :chat-id -100200300}
  :action :skip
  :expected {:error :field-required}
  :note "salary is required, skip not allowed"}

 ;; === Skip on required field (stack) ===
 {:scenario :skip-required-stack
  :session {:state :step/stack
            :step-idx 1
            :data {:salary "150k USD"}
            :created-at #inst "2026-03-01T10:00:00Z"
            :user-id 111222
            :chat-id -100200300}
  :action :skip
  :expected {:error :field-required}
  :note "stack is required, skip not allowed"}

 ;; === Skip on required field (role) ===
 {:scenario :skip-required-role
  :session {:state :step/role
            :step-idx 2
            :data {:salary "150k USD" :stack "Clojure"}
            :created-at #inst "2026-03-01T10:00:00Z"
            :user-id 111222
            :chat-id -100200300}
  :action :skip
  :expected {:error :field-required}
  :note "role is required, skip not allowed"}

 ;; === Back on first step ===
 {:scenario :back-on-first-step
  :session {:state :step/salary
            :step-idx 0
            :data {}
            :created-at #inst "2026-03-01T10:00:00Z"
            :user-id 111222
            :chat-id -100200300}
  :action :back
  :expected-state :step/salary
  :note "First step, back is no-op — stays on salary"}

 ;; === Resume existing session (/register while mid-form) ===
 {:scenario :resume-existing
  :session {:state :step/role
            :step-idx 2
            :data {:salary "150k USD" :stack "Clojure, ClojureScript"}
            :created-at #inst "2026-03-01T10:00:00Z"
            :user-id 111222
            :chat-id -100200300}
  :action :register
  :expected-state :step/role
  :note "/register with active session resumes from current step"}

 ;; === Callback from stale/wrong message ===
 {:scenario :stale-callback
  :session {:state :step/stack
            :step-idx 1
            :data {:salary "150k USD"}
            :created-at #inst "2026-03-01T10:00:00Z"
            :user-id 111222
            :chat-id -100200300
            :message-id 42}
  :callback-message-id 37
  :action :input
  :input "Clojure"
  :expected {:ignored true}
  :note "Callback from message 37, but session tracks message 42 — ignore silently"}

 ;; === Session not found (user never started registration) ===
 {:scenario :no-session
  :user-id 999999
  :chat-id -100200300
  :action :input
  :input "hello"
  :expected nil
  :note "get-session returns nil for unknown user+chat pair"}

 ;; === Expired session cleanup ===
 {:scenario :cleanup-expired
  :sessions
  {[111222 -100200300]
   {:state :step/salary :step-idx 0 :data {}
    :created-at #inst "2026-02-20T10:00:00Z"
    :user-id 111222 :chat-id -100200300}

   [333444 -100200300]
   {:state :step/bio :step-idx 4
    :data {:salary "120k EUR" :stack "TypeScript" :role "Frontend Lead"}
    :created-at #inst "2026-03-04T14:30:00Z"
    :user-id 333444 :chat-id -100200300}

   [555666 -100500600]
   {:state :confirm :step-idx 5
    :data {:salary "90k USD" :stack "Python" :role "Backend Dev"}
    :created-at #inst "2026-02-15T08:00:00Z"
    :user-id 555666 :chat-id -100500600}}
  :current-time #inst "2026-03-05T00:00:00Z"
  :expected-remaining-keys [[333444 -100200300]]
  :note "Two of three sessions expired (> 7 days), only 333444 remains"}]
