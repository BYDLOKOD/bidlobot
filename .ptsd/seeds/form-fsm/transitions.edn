;; transitions.edn
;; State machine transitions for the profile registration form.
;; Step order: salary -> stack -> role -> location -> bio -> confirm -> completed
;; Each entry describes: from-state + action + input => expected-state
;; Actions: :input (user provides value), :back, :skip, :cancel, :confirm, :register

[;; === Happy path: full registration ===
 {:from-state :idle
  :action :register
  :input nil
  :expected-state :step/salary}

 {:from-state :step/salary
  :action :input
  :input "150k USD"
  :expected-state :step/stack}

 {:from-state :step/stack
  :action :input
  :input "Clojure, ClojureScript"
  :expected-state :step/role}

 {:from-state :step/role
  :action :input
  :input "Senior Engineer"
  :expected-state :step/location}

 {:from-state :step/location
  :action :input
  :input "Berlin, UTC+1"
  :expected-state :step/bio}

 {:from-state :step/bio
  :action :input
  :input "Functional programming enthusiast. 10 years in Clojure."
  :expected-state :confirm}

 {:from-state :confirm
  :action :confirm
  :input nil
  :expected-state :completed}

 ;; === Back navigation ===
 {:from-state :step/salary
  :action :back
  :input nil
  :expected-state :step/salary
  :note "First step — cannot go back, stays on salary"}

 {:from-state :step/stack
  :action :back
  :input nil
  :expected-state :step/salary}

 {:from-state :step/role
  :action :back
  :input nil
  :expected-state :step/stack}

 {:from-state :step/location
  :action :back
  :input nil
  :expected-state :step/role}

 {:from-state :step/bio
  :action :back
  :input nil
  :expected-state :step/location}

 {:from-state :confirm
  :action :back
  :input nil
  :expected-state :step/bio}

 ;; === Skip on optional fields ===
 {:from-state :step/location
  :action :skip
  :input nil
  :expected-state :step/bio
  :note "location is optional — skip allowed"}

 {:from-state :step/bio
  :action :skip
  :input nil
  :expected-state :confirm
  :note "bio is optional — skip allowed"}

 ;; === Skip on required fields (error) ===
 {:from-state :step/salary
  :action :skip
  :input nil
  :expected-state :step/salary
  :expected-error :field-required
  :note "salary is required — skip rejected"}

 {:from-state :step/stack
  :action :skip
  :input nil
  :expected-state :step/stack
  :expected-error :field-required
  :note "stack is required — skip rejected"}

 {:from-state :step/role
  :action :skip
  :input nil
  :expected-state :step/role
  :expected-error :field-required
  :note "role is required — skip rejected"}

 ;; === Cancel from any state ===
 {:from-state :step/salary
  :action :cancel
  :input nil
  :expected-state :idle}

 {:from-state :step/stack
  :action :cancel
  :input nil
  :expected-state :idle}

 {:from-state :step/role
  :action :cancel
  :input nil
  :expected-state :idle}

 {:from-state :step/location
  :action :cancel
  :input nil
  :expected-state :idle}

 {:from-state :step/bio
  :action :cancel
  :input nil
  :expected-state :idle}

 {:from-state :confirm
  :action :cancel
  :input nil
  :expected-state :idle}]
