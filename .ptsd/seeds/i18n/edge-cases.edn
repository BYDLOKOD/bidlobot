;; i18n edge cases: fallback scenarios, missing keys, nil inputs.
;; Tests the full fallback chain: requested lang -> :en -> key as string.

{:description "Edge case inputs for the t function and language detection"

 :cases
 [;; 1. Key missing in all languages -> returns key as string
  {:description "Nonexistent key returns stringified key"
   :call        "(t ztx :en :nonexistent/key)"
   :lang        :en
   :key         :nonexistent/key
   :expected    ":nonexistent/key"}

  ;; 2. Unsupported language -> fallback to :en
  {:description "German (unsupported) falls back to English"
   :call        "(t ztx :de :form/title)"
   :lang        :de
   :key         :form/title
   :expected    "Profile Registration"}

  ;; 3. Key exists in :ru but not in :en (hypothetical)
  {:description "Key only in :ru — returns :ru value when :ru requested"
   :call        "(t ztx :ru :ru-only/key)"
   :lang        :ru
   :key         :ru-only/key
   :setup       {:ru {:ru-only/key "\u0422\u043e\u043b\u044c\u043a\u043e \u0440\u0443\u0441\u0441\u043a\u0438\u0439"}}
   :expected    "\u0422\u043e\u043b\u044c\u043a\u043e \u0440\u0443\u0441\u0441\u043a\u0438\u0439"}

  ;; 4. Nil language -> uses default from config
  {:description "Nil language parameter -> default language (:en)"
   :call        "(t ztx nil :form/title)"
   :lang        nil
   :key         :form/title
   :expected    "Profile Registration"}

  ;; 5. Nil key -> returns ":nil" or empty string (implementation decides)
  {:description "Nil key"
   :call        "(t ztx :en nil)"
   :lang        :en
   :key         nil
   :expected    ""}

  ;; 6. Fallback chain: :de -> :en -> key
  {:description "Full fallback: unsupported lang + key exists in :en"
   :call        "(t ztx :de :profile/saved)"
   :lang        :de
   :key         :profile/saved
   :expected    "Profile saved successfully!"}

  ;; 7. Fallback chain: :de -> :en missing too -> key as string
  {:description "Full fallback to key string when missing everywhere"
   :call        "(t ztx :de :totally/missing)"
   :lang        :de
   :key         :totally/missing
   :expected    ":totally/missing"}

  ;; 8. Interpolation with missing key -> falls back, then interpolates
  {:description "Fallback to :en then interpolate"
   :call        "(t ztx :de :form/progress {:current 3 :total 5})"
   :lang        :de
   :key         :form/progress
   :vars        {:current 3 :total 5}
   :expected    "Step 3 of 5"}

  ;; 9. Empty string as translation value
  {:description "Translation value is empty string"
   :setup       {:en {:empty/key ""}}
   :lang        :en
   :key         :empty/key
   :expected    ""}

  ;; 10. Key with no namespace (just keyword)
  {:description "Simple keyword without namespace"
   :setup       {:en {:greeting "Hello!"}}
   :lang        :en
   :key         :greeting
   :expected    "Hello!"}

  ;; 11. Nil ztx context
  {:description "Nil zen context throws or returns key as string"
   :call        "(t nil :en :form/title)"
   :lang        :en
   :key         :form/title
   :expected    {:error :invalid-context}}

  ;; 12. Both vars present but template has no placeholders
  {:description "Vars passed but template has no placeholders"
   :lang        :en
   :key         :form/complete
   :vars        {:foo "bar"}
   :expected    "Registration complete!"}

  ;; 13. Repeated placeholder
  {:description "Same placeholder appears twice in template"
   :setup       {:en {:test/repeat "{name} and {name}"}}
   :lang        :en
   :key         :test/repeat
   :vars        {:name "Alice"}
   :expected    "Alice and Alice"}]}
