;; Sample Telegram update structures for each supported update type.
;; Each entry includes the raw update, its detected type, and expected
;; routing target. Used to test the polling loop and update router.

{:description "Telegram updates with type detection and routing expectations"

 ;; --- Message updates ---
 :message-updates
 [{:description "Text command /start in private chat"
   :update
   {:update_id 200001
    :message
    {:message_id 1
     :from       {:id            294817365
                  :is_bot        false
                  :first_name    "Alexei"
                  :username      "veschin"
                  :language_code "ru"}
     :chat       {:id   294817365
                  :type "private"}
     :date       1709625600
