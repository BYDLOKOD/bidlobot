;; edge-cases.edn
;; Edge cases for profiles: @ prefix handling, case-insensitive lookup,
;; missing username, bio length limits, cross-chat isolation.

[;; === Username with @ prefix ===
 {:scenario :at-prefix-stripped
  :input-username "@veschin"
  :expected-lookup "veschin"
  :note "Leading @ is stripped before lookup"}

 {:scenario :at-prefix-query
  :ast {:cmd :user :args ["@alex_dev" :get :salary]}
  :chat-id -100200300
  :expected-lookup-username "alex_dev"
  :expected {:result "120k EUR" :title "alex_dev's salary"}
  :note "@ in inline query is stripped"}

 ;; === Case-insensitive username lookup ===
 {:scenario :uppercase-username
  :input-username "VESCHIN"
  :chat-id -100200300
  :expected-match {:profile/username "veschin"}
  :note "Lookup is case-insensitive"}

 {:scenario :mixed-case-username
  :input-username "Alex_Dev"
  :chat-id -100200300
  :expected-match {:profile/username "alex_dev"}
  :note "Mixed case normalized to lowercase"}

 {:scenario :case-in-query
  :ast {:cmd :user :args ["MARIA_FE" :get :stack]}
  :chat-id -100200300
  :expected {:result "Kotlin, Spring Boot, PostgreSQL"
             :title "maria_fe's stack"}
  :note "Uppercase in query, case-insensitive match"}

 ;; === User with no Telegram username ===
 {:scenario :no-username
  :profile {:xt/id :profile/888999-100200300
            :profile/user-id 888999
            :profile/chat-id -100200300
            :profile/username nil
            :profile/salary "100k USD"
            :profile/stack "Java, Spring"
            :profile/role "Developer"
            :profile/location nil
            :profile/bio nil
            :profile/created-at #inst "2026-02-25T12:00:00Z"
            :profile/updated-at #inst "2026-02-25T12:00:00Z"}
  :note "User has no @username; must be looked up by user-id, display shows first_name"}

 {:scenario :no-username-lookup-by-id
  :user-id 888999
  :chat-id -100200300
  :expected-found true
  :note "Profile found by user-id when username is nil"}

 ;; === Bio exceeding 500 character limit ===
 {:scenario :bio-too-long
  :input-bio "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum. Extra text to push this past five hundred characters total length limit set by zen schema maximum."
  :char-count 556
  :expected {:error :validation-failed
             :field :bio
             :reason "max-length 500 exceeded"}
  :note "Bio > 500 chars rejected by zen schema validation"}

 {:scenario :bio-at-limit
  :input-bio "Exactly at the character limit. This bio is carefully constructed to be precisely five hundred characters long which is the maximum allowed by the zen schema for the bio field in a DoxMe profile. This ensures edge case testing of the exact boundary condition. It includes realistic content about a developer working with distributed systems and cloud infrastructure who enjoys mentoring junior engineers and contributing to open source projects in their spare time. Padding text for exact length here."
  :char-count 500
  :expected {:valid true}
  :note "Bio at exactly 500 chars is accepted"}

 ;; === Cross-chat profile isolation ===
 {:scenario :same-user-different-chats
  :user-id 111222
  :username "veschin"
  :chat-a {:chat-id -100200300
           :expected-salary "150k USD"
           :expected-role "Senior Engineer"}
  :chat-b {:chat-id -100500600
           :expected-salary "160k USD"
           :expected-role "Platform Engineer"}
  :note "Same user has separate profiles per chat with different data"}

 ;; === Profile not found in specific chat ===
 {:scenario :user-exists-in-other-chat-only
  :username "dmitry_ops"
  :chat-id -100200300
  :expected {:error :user-not-found}
  :note "dmitry_ops has profile in -100500600 but not in -100200300"}

 ;; === @ combined with case mismatch ===
 {:scenario :at-prefix-plus-case
  :input-username "@VESCHIN"
  :chat-id -100200300
  :expected-lookup "veschin"
  :expected-found true
  :note "Both @ stripping and case normalization applied"}]
