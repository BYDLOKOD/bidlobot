;; evaluator.edn
;; Parsed query ASTs (output of query-lang parser) paired with expected
;; evaluation results. The evaluator connects AST to XTDB profile data.
;; Assumes profiles from profiles.edn are loaded in XTDB.

[;; === Successful :user queries ===

 {:ast {:cmd :user :args ["veschin" :get :salary]}
  :chat-id -100200300
  :expected {:result "150k USD"
             :title "veschin's salary"}}

 {:ast {:cmd :user :args ["veschin" :get :stack]}
  :chat-id -100200300
  :expected {:result "Clojure, ClojureScript, Datomic"
             :title "veschin's stack"}}

 {:ast {:cmd :user :args ["veschin" :get :role]}
  :chat-id -100200300
  :expected {:result "Senior Engineer"
             :title "veschin's role"}}

 {:ast {:cmd :user :args ["veschin" :get :location]}
  :chat-id -100200300
  :expected {:result "Berlin, UTC+1"
             :title "veschin's location"}}

 {:ast {:cmd :user :args ["veschin" :get :bio]}
  :chat-id -100200300
  :expected {:result "Functional programming enthusiast. 10 years in Clojure. Open source contributor."
             :title "veschin's bio"}}

 {:ast {:cmd :user :args ["veschin" :profile]}
  :chat-id -100200300
  :expected {:result "salary: 150k USD\nstack: Clojure, ClojureScript, Datomic\nrole: Senior Engineer\nlocation: Berlin, UTC+1\nbio: Functional programming enthusiast. 10 years in Clojure. Open source contributor."
             :title "veschin's profile"}}

 {:ast {:cmd :user :args ["alex_dev" :get :salary]}
  :chat-id -100200300
  :expected {:result "120k EUR"
             :title "alex_dev's salary"}}

 ;; === Same user, different chat ===
 {:ast {:cmd :user :args ["veschin" :get :salary]}
  :chat-id -100500600
  :expected {:result "160k USD"
             :title "veschin's salary"}
  :note "Same user, different chat has different salary"}

 ;; === Error: user not found ===

 {:ast {:cmd :user :args ["nonexistent" :get :salary]}
  :chat-id -100200300
  :expected {:error :user-not-found}}

 {:ast {:cmd :user :args ["ghost_user" :profile]}
  :chat-id -100200300
  :expected {:error :user-not-found}}

 ;; === Error: field not found ===

 {:ast {:cmd :user :args ["veschin" :get :nonexistent]}
  :chat-id -100200300
  :expected {:error :field-not-found}}

 {:ast {:cmd :user :args ["veschin" :get :email]}
  :chat-id -100200300
  :expected {:error :field-not-found}}

 ;; === :help command ===

 {:ast {:cmd :help :args []}
  :chat-id -100200300
  :expected {:title "Help"
             :result-contains "Available commands"}}

 {:ast {:cmd :help :args [:user]}
  :chat-id -100200300
  :expected {:title "Help: :user"
             :result-contains ":user <username> :get <field>"}}

 {:ast {:cmd :help :args [:chat]}
  :chat-id -100200300
  :expected {:title "Help: :chat"
             :result-contains ":chat"}}

 ;; === Optional field that is nil ===

 {:ast {:cmd :user :args ["alex_dev" :get :bio]}
  :chat-id -100200300
  :expected {:error :field-not-found}
  :note "alex_dev has no bio (nil) — treated as not found"}

 {:ast {:cmd :user :args ["maria_fe" :get :location]}
  :chat-id -100200300
  :expected {:error :field-not-found}
  :note "maria_fe has no location (nil) — treated as not found"}

 ;; === Profile omits nil fields ===

 {:ast {:cmd :user :args ["alex_dev" :profile]}
  :chat-id -100200300
  :expected {:result "salary: 120k EUR\nstack: TypeScript, React, Node.js\nrole: Frontend Lead\nlocation: Amsterdam, UTC+1"
             :title "alex_dev's profile"}
  :note "bio is nil, omitted from profile view"}]
