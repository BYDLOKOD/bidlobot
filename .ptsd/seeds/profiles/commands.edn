;; commands.edn
;; Telegram command inputs (/register, /profile, /update) and expected results.
;; Tests the command handler layer that connects TG updates to profile operations.

[;; === /register ===

 {:command "/register"
  :context {:chat-type :group
            :user-id 999000
            :chat-id -100200300
            :username "new_user"}
  :expected {:action :send-deep-link
             :note "In group chat, send deep link button to private chat"}}

 {:command "/register"
  :context {:chat-type :private
            :user-id 999000
            :chat-id 999000
            :username "new_user"}
  :expected {:action :start-form
             :initial-state :step/salary
             :note "In private chat, start registration form"}}

 {:command "/register"
  :context {:chat-type :private
            :user-id 111222
            :chat-id 111222
            :username "veschin"
            :existing-session {:state :step/role :step-idx 2}}
  :expected {:action :resume-form
             :state :step/role
             :note "Resume existing active session"}}

 ;; === /profile ===

 {:command "/profile"
  :context {:user-id 111222
            :chat-id -100200300
            :username "veschin"}
  :expected {:action :show-profile
             :profile {:salary "150k USD"
                       :stack "Clojure, ClojureScript, Datomic"
                       :role "Senior Engineer"
                       :location "Berlin, UTC+1"
                       :bio "Functional programming enthusiast. 10 years in Clojure. Open source contributor."}}}

 {:command "/profile @alex_dev"
  :context {:user-id 111222
            :chat-id -100200300
            :username "veschin"}
  :expected {:action :show-profile
             :target-username "alex_dev"
             :profile {:salary "120k EUR"
                       :stack "TypeScript, React, Node.js"
                       :role "Frontend Lead"
                       :location "Amsterdam, UTC+1"}}}

 {:command "/profile @nonexistent"
  :context {:user-id 111222
            :chat-id -100200300}
  :expected {:action :error
             :error :profile/not-found}}

 {:command "/profile"
  :context {:user-id 999000
            :chat-id -100200300
            :username "unregistered"}
  :expected {:action :error
             :error :error/not-registered}}

 ;; === /update ===

 {:command "/update :salary 200k USD"
  :context {:user-id 111222
            :chat-id -100200300
            :username "veschin"}
  :expected {:action :update-field
             :field :salary
             :value "200k USD"
             :message :profile/updated}}

 {:command "/update :stack Clojure, Rust"
  :context {:user-id 111222
            :chat-id -100200300
            :username "veschin"}
  :expected {:action :update-field
             :field :stack
             :value "Clojure, Rust"
             :message :profile/updated}}

 {:command "/update :nonexistent value"
  :context {:user-id 111222
            :chat-id -100200300}
  :expected {:action :error
             :error :unknown-field}}

 {:command "/update"
  :context {:user-id 111222
            :chat-id -100200300
            :username "veschin"}
  :expected {:action :start-edit-form
             :note "No args — start edit form via form-fsm"}}

 {:command "/update :salary 200k"
  :context {:user-id 999000
            :chat-id -100200300
            :username "unregistered"}
  :expected {:action :error
             :error :error/not-registered}}]
