;; XTDB CRUD operation seeds.
;; Each entry defines an operation with its inputs, expected outputs, and
;; any preconditions (e.g., documents that must exist before the operation).

{:description "put/get/delete/query operations with inputs and expected outputs"

 ;; --- PUT operations ---
 :put-operations
 [{:description "Put a new profile document"
   :operation   :put-doc
   :input       {:xt/id              :profile/294817365-(-1001987654321)
                 :profile/user-id    294817365
                 :profile/chat-id    -1001987654321
                 :profile/username   "veschin"
                 :profile/salary     "150k USD"
                 :profile/stack      "Clojure, TypeScript"
                 :profile/role       "Senior Backend Engineer"
                 :profile/created-at #inst "2026-01-15T10:30:00.000Z"
                 :profile/updated-at #inst "2026-01-15T10:30:00.000Z"}
   :expected    {:tx-committed? true}}

  {:description "Put user-stats document"
   :operation   :put-doc
   :input       {:xt/id                    :user-stats/294817365-(-1001987654321)
                 :user-stats/user-id       294817365
                 :user-stats/chat-id       -1001987654321
                 :user-stats/message-count 1
                 :user-stats/first-seen    #inst "2026-03-05T08:42:00.000Z"
                 :user-stats/last-seen     #inst "2026-03-05T08:42:00.000Z"}
   :expected    {:tx-committed? true}}

  {:description "Put overwrites existing document (last write wins)"
   :precondition {:xt/id :profile/294817365-(-1001987654321)
                  :profile/salary "150k USD"}
   :operation    :put-doc
   :input        {:xt/id           :profile/294817365-(-1001987654321)
                  :profile/salary  "200k USD"
                  :profile/updated-at #inst "2026-03-05T12:00:00.000Z"}
   :expected     {:tx-committed? true}
   :verify       {:call    "(get-doc node :profile/294817365-(-1001987654321))"
                  :returns {:xt/id           :profile/294817365-(-1001987654321)
                            :profile/salary  "200k USD"
                            :profile/updated-at #inst "2026-03-05T12:00:00.000Z"}}}]

 ;; --- GET operations ---
 :get-operations
 [{:description "Get existing profile document"
   :operation   :get-doc
   :precondition {:xt/id              :profile/294817365-(-1001987654321)
                  :profile/user-id    294817365
                  :profile/username   "veschin"
                  :profile/salary     "150k USD"}
   :input       :profile/294817365-(-1001987654321)
   :expected    {:xt/id              :profile/294817365-(-1001987654321)
                 :profile/user-id    294817365
                 :profile/username   "veschin"
                 :profile/salary     "150k USD"}}

  {:description "Get non-existent document returns nil"
   :operation   :get-doc
   :input       :profile/999999999-(-1001987654321)
   :expected    nil}

  {:description "Get warning by UUID"
   :operation   :get-doc
   :precondition {:xt/id       :warn/a1b2c3d4-e5f6-7890-abcd-ef1234567890
                  :warn/reason "Spam links in chat"}
   :input       :warn/a1b2c3d4-e5f6-7890-abcd-ef1234567890
   :expected    {:xt/id       :warn/a1b2c3d4-e5f6-7890-abcd-ef1234567890
                 :warn/reason "Spam links in chat"}}]

 ;; --- DELETE operations ---
 :delete-operations
 [{:description "Delete existing document"
   :operation   :delete-doc
   :precondition {:xt/id :profile/294817365-(-1001987654321)}
   :input       :profile/294817365-(-1001987654321)
   :expected    {:tx-committed? true}
   :verify      {:call    "(get-doc node :profile/294817365-(-1001987654321))"
                 :returns nil}}

  {:description "Delete non-existent document (no-op, still returns tx receipt)"
   :operation   :delete-doc
   :input       :profile/000000000-(-1001987654321)
   :expected    {:tx-committed? true}}]

 ;; --- QUERY operations ---
 :query-operations
 [{:description "Query all profiles in a chat"
   :operation   :query
   :query       {:find  [?e ?username]
                 :where [[?e :profile/chat-id chat-id]
                         [?e :profile/username ?username]]}
   :params      {:chat-id -1001987654321}
   :expected    [[:profile/294817365-(-1001987654321) "veschin"]
                 [:profile/518293746-(-1001987654321) "anna_dev"]
                 [:profile/738192045-(-1001987654321) "max_clj"]]}

  {:description "Query top users by message count in a chat"
   :operation   :query
   :query       {:find     [?username ?count]
                 :where    [[?e :user-stats/chat-id chat-id]
                            [?e :user-stats/user-id ?uid]
                            [?p :profile/user-id ?uid]
                            [?p :profile/chat-id chat-id]
                            [?p :profile/username ?username]
                            [?e :user-stats/message-count ?count]]
                 :order-by [[?count :desc]]
                 :limit    10}
   :params      {:chat-id -1001987654321}
   :expected    [["veschin" 4827]
                 ["anna_dev" 1293]
                 ["max_clj" 312]]}

  {:description "Query warnings for a specific user in a chat"
   :operation   :query
   :query       {:find  [?e ?reason ?ts]
                 :where [[?e :warn/user-id user-id]
                         [?e :warn/chat-id chat-id]
                         [?e :warn/reason ?reason]
                         [?e :warn/created-at ?ts]]
                 :order-by [[?ts :asc]]}
   :params      {:user-id 738192045 :chat-id -1001987654321}
   :expected    [[:warn/a1b2c3d4-e5f6-7890-abcd-ef1234567890 "Spam links in chat"            #inst "2026-02-28T16:30:00.000Z"]
                 [:warn/b2c3d4e5-f6a7-8901-bcde-f12345678901 "Repeated off-topic messages"    #inst "2026-03-02T11:15:00.000Z"]]}

  {:description "Query with no matching results returns empty vector"
   :operation   :query
   :query       {:find  [?e]
                 :where [[?e :profile/chat-id chat-id]]}
   :params      {:chat-id -1009999999999}
   :expected    []}]}
