;; XTDB edge case inputs and expected errors.
;; Covers error conditions from the PRD edge cases table plus additional
;; boundary scenarios for robust testing.

{:description "Edge case inputs and expected error responses for XTDB operations"

 :cases
 [;; 1. put-doc without :xt/id
  {:description "Document missing :xt/id field"
   :operation   :put-doc
   :input       {:profile/user-id 294817365
                 :profile/salary  "150k USD"}
   :expected    {:error   :missing-id
                 :message "Document must have :xt/id"}}

  ;; 2. get-doc for non-existent ID
  {:description "Getting a document that does not exist"
   :operation   :get-doc
   :input       :profile/000000000-(-1009999999999)
   :expected    nil}

  ;; 3. create-node with non-writable path
  {:description "RocksDB storage with non-writable directory"
   :operation   :create-node
   :input       {:storage :rocksdb :path "/root/no-access/xtdb"}
   :expected    {:error   :storage-error
                 :message "Cannot write to storage path: /root/no-access/xtdb"}}

  ;; 4. close-node on already-closed node
  {:description "Closing a node that was already closed"
   :operation   :close-node
   :precondition :node-already-closed
   :expected    {:error :node-closed
                 :message "Node is already closed"}}

  ;; 5. delete-doc for non-existent ID (no-op)
  {:description "Deleting a non-existent document is a no-op"
   :operation   :delete-doc
   :input       :profile/nonexistent-(-1001987654321)
   :expected    {:tx-committed? true}}

  ;; 6. put-doc with nil :xt/id
  {:description "Document with nil as :xt/id"
   :operation   :put-doc
   :input       {:xt/id nil :profile/salary "100k"}
   :expected    {:error   :missing-id
                 :message "Document must have :xt/id"}}

  ;; 7. Query with malformed Datalog
  {:description "Invalid Datalog query syntax"
   :operation   :query
   :query       {:find [?e] :where "not-a-clause-vector"}
   :params      {}
   :expected    {:error   :query-error
                 :message "Invalid query syntax"}}

  ;; 8. Operations after node closed
  {:description "put-doc on a closed node"
   :operation   :put-doc
   :precondition :node-already-closed
   :input       {:xt/id :profile/test :profile/salary "100k"}
   :expected    {:error :node-closed
                 :message "Node is already closed"}}

  ;; 9. Concurrent writes to same :xt/id (last write wins)
  {:description "Two concurrent puts to the same document ID"
   :operation   :concurrent-put
   :inputs      [{:xt/id :profile/294817365-(-1001987654321) :profile/salary "150k USD"}
                 {:xt/id :profile/294817365-(-1001987654321) :profile/salary "200k USD"}]
   :expected    {:description "Second write wins — document has 200k USD"
                 :verify {:call    "(get-doc node :profile/294817365-(-1001987654321))"
                          :returns {:xt/id :profile/294817365-(-1001987654321)
                                    :profile/salary "200k USD"}}}}

  ;; 10. Very large document
  {:description "Document with a large bio field (near max)"
   :operation   :put-doc
   :input       {:xt/id        :profile/111222333-(-1001987654321)
                 :profile/bio  "<500-char-string>"
                 :profile/salary "100k"}
   :expected    {:tx-committed? true}}

  ;; 11. Special characters in keyword IDs
  {:description "ID with special characters"
   :operation   :put-doc
   :input       {:xt/id              :profile/294817365-(-1001987654321)
                 :profile/username   "user.name-test_123"}
   :expected    {:tx-committed? true}}

  ;; 12. create-node with memory storage (valid, for dev/test)
  {:description "In-memory node creation succeeds"
   :operation   :create-node
   :input       {:storage :memory}
   :expected    {:node-open? true}}

  ;; 13. create-node with unknown storage type
  {:description "Unknown storage type"
   :operation   :create-node
   :input       {:storage :dynamodb :path "/data"}
   :expected    {:error   :storage-error
                 :message "Unknown storage type: :dynamodb"}}]}
