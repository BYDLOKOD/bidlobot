;; youtube-summary/edge-cases.edn
;; Edge cases: rate limit exceeded, missing API keys, no subtitles, video duration limits.

{:description "Edge cases for YouTube summary feature"

 :rate-limit-exceeded
 {:scenario "Chat has exceeded 10 summaries per hour"
  :chat-id -1001234567890
  :rate-limit {:max-per-hour 10
               :window-seconds 3600}
  :current-timestamps
  [#inst "2026-03-05T08:05:00.000Z"
   #inst "2026-03-05T08:10:00.000Z"
   #inst "2026-03-05T08:15:00.000Z"
   #inst "2026-03-05T08:20:00.000Z"
   #inst "2026-03-05T08:25:00.000Z"
   #inst "2026-03-05T08:30:00.000Z"
   #inst "2026-03-05T08:35:00.000Z"
   #inst "2026-03-05T08:40:00.000Z"
   #inst "2026-03-05T08:45:00.000Z"
   #inst "2026-03-05T08:50:00.000Z"]
  :request-time #inst "2026-03-05T08:55:00.000Z"
  :expected {:error :rate-limited
             :message "Summary limit reached. Try again later."}}

 :rate-limit-window-expired
 {:scenario "Old timestamps have expired, slot available"
  :chat-id -1001234567890
  :current-timestamps
  [#inst "2026-03-05T07:00:00.000Z"
   #inst "2026-03-05T07:05:00.000Z"
   #inst "2026-03-05T07:10:00.000Z"
   #inst "2026-03-05T08:30:00.000Z"
   #inst "2026-03-05T08:35:00.000Z"]
  :request-time #inst "2026-03-05T08:55:00.000Z"
  :expected {:error nil
             :note "Only 2 timestamps are within the last hour, so request is allowed"
             :active-count 2}}

 :no-glm-api-key
 {:scenario "GLM_API_KEY environment variable is not set"
  :env {"GLM_API_KEY" nil
        "YOUTUBE_API_KEY" "AIzaSyC_valid_key_here"}
  :command "/summarize https://www.youtube.com/watch?v=dQw4w9WgXcQ"
  :expected {:error :not-configured
             :message "YouTube summary feature is not configured. Missing GLM API key."}}

 :no-youtube-api-key
 {:scenario "YOUTUBE_API_KEY environment variable is not set"
  :env {"GLM_API_KEY" "glm-key-valid"
        "YOUTUBE_API_KEY" nil}
  :command "/summarize https://www.youtube.com/watch?v=dQw4w9WgXcQ"
  :expected {:error :not-configured
             :message "YouTube summary feature is not configured. Missing YouTube API key."}}

 :both-keys-missing
 {:scenario "Both API keys are missing"
  :env {"GLM_API_KEY" nil
        "YOUTUBE_API_KEY" nil}
  :command "/summarize https://www.youtube.com/watch?v=dQw4w9WgXcQ"
  :expected {:error :not-configured
             :message "YouTube summary feature is not configured. Missing GLM API key."}}

 :no-subtitles
 {:scenario "Video exists but has no captions/subtitles available"
  :video-id "Ks-_Mh1QhMc"
  :video-metadata {:title "Coding Session: No Commentary"
                   :duration-seconds 1510}
  :captions-response {:kind "youtube#captionListResponse"
                      :items []}
  :expected {:error :no-subtitles
             :message "No subtitles available for this video."}}

 :glm-timeout
 {:scenario "GLM API request times out after 30 seconds"
  :video-id "LJ4d5CGN6bI"
  :timeout-ms 30000
  :expected {:error :timeout
             :message "Summary service timed out. Please try again."}}

 :glm-rate-limited
 {:scenario "GLM API returns HTTP 429 (rate limit)"
  :video-id "LJ4d5CGN6bI"
  :api-response {:status 429
                 :headers {"retry-after" "60"}
                 :body {:error {:message "Rate limit exceeded"
                                :type "rate_limit_error"
                                :code "429"}}}
  :expected {:error :rate-limited
             :message "Summary service is busy. Please try again in a minute."}}

 :video-exactly-1-hour
 {:scenario "Video is exactly 1 hour — should be accepted (boundary)"
  :video-id "M7lc1UVf-VE"
  :duration "PT1H"
  :duration-seconds 3600
  :expected {:valid true
             :note "Exactly 1 hour is within the limit"}}

 :video-just-over-1-hour
 {:scenario "Video is 1 hour and 1 second — should be rejected"
  :video-id "ZZ5LpwO-An4"
  :duration "PT1H0M1S"
  :duration-seconds 3601
  :expected {:error :video-too-long
             :message "Video too long (max 1 hour)."}}

 :video-exactly-1-minute
 {:scenario "Video is exactly 1 minute — should be accepted (boundary)"
  :video-id "_-x0WkL3bXE"
  :duration "PT1M"
  :duration-seconds 60
  :expected {:valid true
             :note "Exactly 1 minute is within the limit"}}

 :video-59-seconds
 {:scenario "Video is 59 seconds — should be rejected as too short"
  :video-id "rfscVS0vtbw"
  :duration "PT59S"
  :duration-seconds 59
  :expected {:error :video-too-short
             :message "Video too short to summarize."}}

 :empty-glm-api-key
 {:scenario "GLM_API_KEY is set but empty string"
  :env {"GLM_API_KEY" ""
        "YOUTUBE_API_KEY" "AIzaSyC_valid_key_here"}
  :expected {:error :invalid-api-key
             :message "YouTube summary feature is not configured. Invalid GLM API key."}}

 :private-or-deleted-video
 {:scenario "Video is private or has been deleted"
  :video-id "XXXXXXXXXXX"
  :expected {:error :video-not-found
             :message "Video not found or unavailable."}}

 :summarize-in-private-chat
 {:scenario "/summarize command in private chat (allowed, unlike /stats)"
  :chat {:id 111222333 :type "private"}
  :command "/summarize https://www.youtube.com/watch?v=dQw4w9WgXcQ"
  :expected {:valid true
             :note "Summarize works in both private and group chats"}}}
