;; edge-cases.edn
;; Edge-case inputs for the query language parser.
;; Covers: usernames with underscores/hyphens, uppercase commands,
;; double colons, tab characters, mixed punctuation in words.

[;; === usernames with special characters ===
 {:input ":user dev_ops :get :salary"
  :expected {:cmd :user :args ["dev_ops" :get :salary]}
  :note "underscore in username"}

 {:input ":user maria-fe :get :stack"
  :expected {:cmd :user :args ["maria-fe" :get :stack]}
  :note "hyphen in username"}

 {:input ":user a_b-c_d :profile"
  :expected {:cmd :user :args ["a_b-c_d" :profile]}
  :note "mixed underscores and hyphens"}

 {:input ":user __leading :get :role"
  :expected {:cmd :user :args ["__leading" :get :role]}
  :note "leading underscores"}

 ;; === double colons ===
 {:input ":user::name"
  :expected {:error :invalid-syntax}
  :note "double colon without space"}

 {:input ":user veschin ::get :salary"
  :expected {:error :invalid-syntax}
  :note "double colon in args"}

 ;; === uppercase command names ===
 {:input ":USER veschin"
  :expected {:error :unknown-command :command "USER"}
  :note "fully uppercase command"}

 {:input ":User veschin"
  :expected {:error :unknown-command :command "User"}
  :note "capitalized command"}

 {:input ":HELP"
  :expected {:error :unknown-command :command "HELP"}
  :note "uppercase help"}

 ;; === tab and mixed whitespace ===
 {:input ":user\tveschin\t:get\t:salary"
  :expected {:cmd :user :args ["veschin" :get :salary]}
  :note "tab-separated tokens"}

 {:input ":user  \t  veschin  \t  :profile"
  :expected {:cmd :user :args ["veschin" :profile]}
  :note "mixed spaces and tabs"}

 ;; === single-character username ===
 {:input ":user x :get :salary"
  :expected {:cmd :user :args ["x" :get :salary]}
  :note "single char username"}

 ;; === numeric-looking username (still a word, not a keyword) ===
 {:input ":user user123 :get :stack"
  :expected {:cmd :user :args ["user123" :get :stack]}
  :note "alphanumeric username"}

 ;; === keyword-only args ===
 {:input ":chat :stats :top :today"
  :expected {:cmd :chat :args [:stats :top :today]}
  :note "multiple keyword args"}

 ;; === trailing whitespace ===
 {:input ":help   "
  :expected {:cmd :help :args []}
  :note "trailing spaces after command"}

 ;; === leading whitespace ===
 {:input "   :user veschin :profile"
  :expected {:cmd :user :args ["veschin" :profile]}
  :note "leading spaces before command"}]
