;; invalid-queries.edn
;; Invalid query inputs that should produce error results.
;; Covers: empty, whitespace-only, unknown commands, too-long queries,
;; missing colon prefix, and invalid syntax patterns.

[;; === empty / whitespace ===
 {:input ""
  :expected {:error :empty-query}}

 {:input "   "
  :expected {:error :empty-query}}

 {:input "\t\t"
  :expected {:error :empty-query}}

 {:input "\n"
  :expected {:error :empty-query}}

 ;; === missing colon prefix ===
 {:input "no colon"
  :expected {:error :invalid-syntax}}

 {:input "user veschin"
  :expected {:error :invalid-syntax}}

 {:input "help"
  :expected {:error :invalid-syntax}}

 ;; === unknown commands ===
 {:input ":unknown-cmd foo"
  :expected {:error :unknown-command :command "unknown-cmd"}}

 {:input ":search veschin"
  :expected {:error :unknown-command :command "search"}}

 {:input ":ban user123"
  :expected {:error :unknown-command :command "ban"}}

 {:input ":stats"
  :expected {:error :unknown-command :command "stats"}}

 ;; === uppercase commands (commands are lowercase only) ===
 {:input ":USER veschin"
  :expected {:error :unknown-command :command "USER"}}

 {:input ":Help"
  :expected {:error :unknown-command :command "Help"}}

 {:input ":CHAT :stats"
  :expected {:error :unknown-command :command "CHAT"}}

 ;; === query too long (> 500 chars) ===
 {:input ":user "
  :expected {:error :query-too-long}}

 ;; === invalid syntax ===
 {:input ":"
  :expected {:error :invalid-syntax}}

 {:input ": "
  :expected {:error :invalid-syntax}}

 {:input "::"
  :expected {:error :invalid-syntax}}]
