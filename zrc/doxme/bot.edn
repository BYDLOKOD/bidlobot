{ns doxme.bot

 ;; === TAGS ===

 ;; Тег для определения полей профиля
 profile-field
 {:zen/tags #{zen/tag zen/schema}
  :zen/desc "Profile field definition for user registration form"
  :type zen/map
  :require #{:type :prompt}
  :keys {:type {:type zen/keyword
                :enum [{:value :string}
                       {:value :integer}
                       {:value :boolean}]}
         :required {:type zen/boolean}
         :zen/desc {:type zen/string}
         :prompt {:type zen/string}
         :default {:type zen/string}
         :max-length {:type zen/integer}
         :validation {:type zen/keyword
                      :enum [{:value :none}
                             {:value :email}
                             {:value :phone}
                             {:value :number}]}}}

 ;; Тег для inline команд
 inline-command
 {:zen/tags #{zen/tag zen/schema}
  :zen/desc "Inline query command definition"
  :type zen/map
  :keys {:command {:type zen/keyword}
         :zen/desc {:type zen/string}
         :syntax {:type zen/string}
         :examples {:type zen/vector :every {:type zen/string}}}}

 ;; Тег для обычных команд бота
 bot-command
 {:zen/tags #{zen/tag zen/schema}
  :zen/desc "Telegram bot command"
  :type zen/map
  :keys {:command {:type zen/string}
         :zen/desc {:type zen/string}
         :handler {:type zen/keyword}}}

 ;; === PROFILE SCHEMA ===

 profile
 {:zen/tags #{zen/schema}
  :zen/desc "User profile data structure"
  :type zen/map
  :keys {:user-id {:type zen/integer}
         :chat-id {:type zen/integer}
         :username {:type zen/string}
         :salary {:type zen/string}
         :stack {:type zen/string}
         :role {:type zen/string}
         :location {:type zen/string}
         :bio {:type zen/string}
         :created-at {:type zen/datetime}
         :updated-at {:type zen/datetime}}}

 ;; === PROFILE FIELDS (тегированные определения) ===

 salary
 {:zen/tags #{profile-field}
  :type :string
  :required true
  :zen/desc "Salary expectation"
  :prompt "Your salary expectation? (e.g., 100k USD)"}

 stack
 {:zen/tags #{profile-field}
  :type :string
  :required true
  :zen/desc "Technology stack"
  :prompt "Your technology stack? (e.g., Clojure, TypeScript)"}

 role
 {:zen/tags #{profile-field}
  :type :string
  :required true
  :zen/desc "Current job role"
  :prompt "Your current role? (e.g., Senior Engineer)"}

 location
 {:zen/tags #{profile-field}
  :type :string
  :required false
  :zen/desc "Location or timezone"
  :prompt "Your location or timezone? (optional)"}

 bio
 {:zen/tags #{profile-field}
  :type :string
  :required false
  :zen/desc "Short bio about yourself"
  :prompt "Tell us about yourself (optional, max 500 chars)"
  :max-length 500}

 ;; === INLINE COMMANDS ===

 user-command
 {:zen/tags #{inline-command}
  :command :user
  :zen/desc "Query user profile information"
  :syntax ":user <username> :get <field>"
  :examples [":user veschin :get :salary"
             ":user veschin :get :stack"
             ":user veschin :profile"]}

 chat-command
 {:zen/tags #{inline-command}
  :command :chat
  :zen/desc "Query chat statistics and data"
  :syntax ":chat :<action>"
  :examples [":chat :users"
             ":chat :stats"]}

 help-command
 {:zen/tags #{inline-command}
  :command :help
  :zen/desc "Show help and available commands"
  :syntax ":help [<command>]"
  :examples [":help"
             ":help :user"]}

 ;; === BOT COMMANDS ===

 start-command
 {:zen/tags #{bot-command}
  :command "/start"
  :zen/desc "Start the bot and show welcome message"
  :handler :start-handler}

 register-command
 {:zen/tags #{bot-command}
  :command "/register"
  :zen/desc "Start registration flow to create profile"
  :handler :register-handler}

 profile-command
 {:zen/tags #{bot-command}
  :command "/profile"
  :zen/desc "View or edit your profile"
  :handler :profile-handler}

 help-bot-command
 {:zen/tags #{bot-command}
  :command "/help"
  :zen/desc "Show bot help and available commands"
  :handler :help-handler}

 ;; === FORM SESSION SCHEMA ===

 form-session
 {:zen/tags #{zen/schema}
  :zen/desc "Multi-step form session state"
  :type zen/map
  :require #{:user-id :chat-id :state :data}
  :keys {:user-id {:type zen/integer}
         :chat-id {:type zen/integer}
         :state {:type zen/keyword}
         :step {:type zen/integer}
         :data {:type zen/map}
         :message-id {:type zen/integer}
         :history {:type zen/vector
                   :every {:type zen/keyword}}
         :created-at {:type zen/datetime}
         :expires-at {:type zen/datetime}}}

 ;; === CONFIGURATION ===

 config
 {:zen/tags #{zen/tag zen/schema}
  :zen/desc "Bot configuration schema"
  :type zen/map
  :require #{:token}
  :keys {:token {:type zen/string}
         :api-url {:type zen/string}
         :default-language {:type zen/keyword
                            :enum [{:value :en}
                                   {:value :ru}]}
         :admin-users {:type zen/vector
                       :every {:type zen/integer}}
         :debug {:type zen/boolean}}}

 bot-config
 {:zen/tags #{config}
  :token #env TG_BOT_TOKEN
  :api-url #env [TG_API_URL "https://api.telegram.org"]
  :default-language #env-keyword [DEFAULT_LANG :en]
  :debug #env-boolean [DEBUG false]}

 ;; === I18N ===

 i18n
 {:en {:bot/name "BidloBot"
       :bot/desc "Profile management bot for team chats"
       :form/title "Profile Registration"
       :form/progress "Step {current} of {total}"
       :form/back "◀️ Back"
       :form/next "Next ▶️"
       :form/skip "⏭️ Skip"
       :form/cancel "❌ Cancel"
       :form/confirm "✅ Confirm"
       :form/complete "Registration complete!"
       :form/expired "Session expired. Please start again with /register"
       :profile/not-found "Profile not found. Register with /register"
       :profile/saved "Profile saved successfully!"
       :profile/updated "Profile updated!"
       :error/invalid-command "Invalid command. Use :help for usage."
       :error/user-not-found "User not found in this chat."
       :error/not-registered "You are not registered. Use /register first."}
  :ru {:bot/name "BidloBot"
